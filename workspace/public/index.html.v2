    const YEARS = [2026,2025,2024,2023,2022,2021,2020,2019,2018,2017,2016,2015,2014,2013,2012,2011,2010,2009,2008,2007,2006,2005,2004,2003,2002,2001,2000,1999,1998,1997,1996,1995,1994,1993,1992,1991,1990,1989,1988,1987,1986,1985,1984,1983,1982,1981,1980,1979,1978,1977,1976,1975,1974,1973,1972,1971,1970,1969,1968,1967,1966,1965,1960,1955,1950,1948,1947,1946,1945,1944,1943,1942,1941,1940];

    // ─── DOM refs ───────────────────────────────────────────────────────────────
    const regionSelect = document.getElementById('region-select');
    const makeSelect  = document.getElementById('make-select');
    const modelSelect = document.getElementById('model-select');
    const yearSelect  = document.getElementById('year-select');
    const searchBtn   = document.getElementById('search-btn');
    const searchForm  = document.getElementById('search-form');
    const resultArea  = document.getElementById('result-area');

    // ─── Populate dropdowns ─────────────────────────────────────────────────────
    // Makes
    MAKES.forEach(m => {
      const opt = document.createElement('option');
      opt.value = m.name;
      opt.textContent = m.name;
      makeSelect.appendChild(opt);
    });

    // ─── Region to Makes mapping ───────────────────────────────────────────────
    const REGION_MAKES = {
      'us': ['AMC', 'Chevrolet', 'Dodge', 'Ford', 'GMC', 'Honda', 'Hummer', 'International', 'Jeep', 'Lincoln', 'Lordstown', 'Nissan', 'Ram', 'Rivian', 'Tesla', 'Toyota'],
      'latam': ['BYD', 'Chevrolet', 'Ford', 'Fiat', 'Volkswagen', 'Toyota', 'Nissan', 'Renault', 'Peugeot'],
      'europe': ['Fiat', 'Ford', 'LDV', 'Mercedes-Benz', 'Peugeot', 'Renault', 'Volkswagen'],
      'asia': ['BYD', 'Toyota', 'Nissan', 'Mitsubishi', 'Isuzu', 'Mazda', 'Honda', 'Hyundai', 'Kia', 'Genesis', 'SsangYong', 'Mahindra', 'Tata', 'Great Wall', 'Foton', 'Suzuki', 'Subaru', 'Tesla'],
      'all': null  // null = all makes
    };

    // Populate makes based on region
    function populateMakesByRegion(region) {
      makeSelect.innerHTML = '<option value="">Select Make</option>';
      modelSelect.innerHTML = '<option value="">Select Model</option>';
      modelSelect.disabled = true;
      yearSelect.disabled = true;
      searchBtn.disabled = true;

      const makesInRegion = region === 'all' ? MAKES.map(m => m.name) : (REGION_MAKES[region] || []);

      makesInRegion.forEach(makeName => {
        const make = MAKES.find(m => m.name === makeName);
        if (make) {
          const opt = document.createElement('option');
          opt.value = make.name;
          opt.textContent = make.name;
          makeSelect.appendChild(opt);
        }
      });

      makeSelect.disabled = false;
    }

    // Initialize with all makes
    populateMakesByRegion('all');

    // Years
    YEARS.forEach(y => {
      const opt = document.createElement('option');
      opt.value = y;
      opt.textContent = y;
      yearSelect.appendChild(opt);
    });


    // ─── Dropdown cascade ───────────────────────────────────────────────────────
    regionSelect.addEventListener('change', () => {
      const region = regionSelect.value;
      populateMakesByRegion(region);
    });

    makeSelect.addEventListener('change', () => {
      const make = makeSelect.value;
      yearSelect.value = '';
      modelSelect.value = '';
      modelSelect.disabled = true;
      searchBtn.disabled = true;

      if (!make) {
        yearSelect.disabled = true;
        return;
      }

      yearSelect.disabled = false;
    });

    // Models that have incomplete data (hp=0 and engine="Engine") — exclude from dropdown
const BAD_MODELS = new Set([
  'B2000/B2200 Pickup 2WD','B2300/B3000/B4000 Pickup 2WD','B2300/B3000/B4000 Pickup 4WD',
  'C10 Pickup 2WD','C15 Pickup 2WD','C1500 Pickup 2WD','C20 Pickup 2WD','C25 Pickup 2WD','C2500 Pickup 2WD',
  'Caballero Pickup 2WD','Comanche Pickup 2WD','Comanche Pickup 4WD','Courier Pickup 2WD','Courier Pickup 4WD',
  'D100/D150 Pickup 2WD','D250 Pickup 2WD','Dakota Pickup 2WD','Dakota Pickup 4WD',
  'El Camino Pickup 2WD',
  'F150 Pickup 2WD','F150 Pickup 2WD CNG','F150 Pickup 2WD FFV','F150 Pickup 2WD HEV','F150 Pickup 2WD Limited',
  'F150 Pickup 4WD','F150 Pickup 4WD FFV','F150 Pickup 4WD HEV','F150 Pickup 4WD Limited','F150 Pickup 4WD XL/XLT',
  'F150 Pickup Tremor 4WD','F150 Pickup Tremor 4WD FFV','F150 Raptor Pickup 4WD',
  'F250 Pickup 2WD','F250 Pickup 2WD CNG','F250 Pickup 4WD',
  'Gladiator Pickup 4WD',
  'Hombre Pickup 2WD','Hombre Pickup 2WD (FFV)','Hombre Pickup 4WD',
  'Hummer EV Pickup','Hummer EV Pickup 2M20','Hummer EV Pickup 2X','Hummer EV Pickup 3X',
  'Hummer EV Pickup MT Tires','Hummer EV Pickup MT Tires 2M20','Hummer EV Pickup MT Tires 2X','Hummer EV Pickup MT Tires 3X',
  'J-10 Pickup 4WD','J-10 Pickup Truck','J-10 Pickup Truck 4WD','J-20 Pickup Truck','J-20 Pickup Truck 4WD',
  'K10 Pickup 4WD','K15 Pickup 4WD','K1500 Pickup 4WD','K20 Pickup 4WD','K25 Pickup 4WD','K2500 Pickup 4WD',
  'Lightning Pickup 2WD',
  'Pickup 2500 2WD','Pickup 2500 4WD','Pickup 2WD','Pickup 2WD 1-Ton','Pickup 4WD',
  'Power Ram 50 Pickup 4WD',
  'R10 Pickup 2WD','R15 Pickup 2WD','R20 (C20) Pickup 2WD','R25 Pickup 2WD',
  'Raider Pickup 2WD','Raider Pickup 4WD',
  'Ram 1500 Pickup 2WD','Ram 1500 Pickup 4WD','Ram 2500 Pickup 2WD','Ram 2500 Pickup 4WD','Ram 50 Pickup 2WD',
  'Rampage Pickup 2WD',
  'Ranger Pickup 2WD','Ranger Pickup 4WD',
  'S10 Pickup 2WD','S10 Pickup 2WD FFV','S10 Pickup 4WD','S15 Pickup 2WD','S15 Pickup 4WD',
  'SSR Pickup 2WD','Scrambler Pickup 4WD',
  'T10 (S10) Pickup 4WD','T15 (S15) Pickup 4WD',
  'V10 (K10) Pickup 4WD','V15 Pickup 4WD','V20 Pickup 4WD','V25 Pickup 4WD',
  'W100/W150 Pickup 4WD','W250 Pickup 4WD'
]);

    yearSelect.addEventListener('change', () => {
      const make = makeSelect.value;
      modelSelect.innerHTML = '<option value="">Select Model</option>';

      if (!yearSelect.value) {
        modelSelect.disabled = true;
        searchBtn.disabled = true;
        return;
      }

      const models = MODELS_BY_MAKE[make] || [];
      models.forEach(m => {
        if (BAD_MODELS.has(m)) return; // filter incomplete Pickup entries
        const opt = document.createElement('option');
        opt.value = m;
        opt.textContent = m;
        modelSelect.appendChild(opt);
      });
      modelSelect.disabled = false;
    });

    modelSelect.addEventListener('change', () => {
      searchBtn.disabled = !makeSelect.value || !modelSelect.value || !yearSelect.value;
    });

    // ─── Format helpers ─────────────────────────────────────────────────────────
    function fmt(v) {
      if (v === null || v === undefined || v === '') return '—';
      return v;
    }

    function fmtNum(n) {
      if (n === null || n === undefined || n === '') return '—';
      return Number(n).toLocaleString();
    }

    // ─── Render result ───────────────────────────────────────────────────────────
    function renderResult(truck) {
      resultArea.innerHTML = `
        <div class="result-card">
          <div class="result-header">
            <h4>${fmt(truck.make)} ${fmt(truck.model)}</h4>
            <span class="year-badge">${truck.year}</span>
          </div>
          <div class="result-body">
            <div class="result-field">
              <label>Engine</label>
              <span>${fmt(truck.engine)}</span>
            </div>
            <div class="result-field">
              <label>Horsepower</label>
              <span>${fmtNum(truck.horsepower)} hp</span>
            </div>
            <div class="result-field">
              <label>Torque</label>
              <span>${fmtNum(truck.torque)} lb-ft</span>
            </div>
            <div class="result-field">
              <label>Transmission</label>
              <span>${fmt(truck.transmission)}</span>
            </div>
            <div class="result-field">
              <label>Drivetrain</label>
              <span>${fmt(truck.drivetrain)}</span>
            </div>
            <div class="result-field">
              <label>Towing Capacity</label>
              <span>${fmtNum(truck.towingCapacity)} lbs</span>
            </div>
            <div class="result-field">
              <label>Payload</label>
              <span>${fmtNum(truck.payload)} lbs</span>
            </div>
            <div class="result-field">
              <label>Bed Length</label>
              <span>${fmt(truck.bedLength)}</span>
            </div>
            <div class="result-field">
              <label>Cab Type</label>
              <span>${fmt(truck.cabType)}</span>
            </div>
            <div class="result-field">
              <label>Fuel Type</label>
              <span>${fmt(truck.fuelType)}</span>
            </div>
            <div class="result-field">
              <label>City MPG</label>
              <span>${fmtNum(truck.cityMpg)} mpg</span>
            </div>
            <div class="result-field">
              <label>Highway MPG</label>
              <span>${fmtNum(truck.highwayMpg)} mpg</span>
            </div>
            <div class="result-field">
              <label>Curb Weight</label>
              <span>${fmtNum(truck.curbWeight)} lbs</span>
            </div>
            <div class="result-field">
              <label>Country</label>
              <span>${fmt(truck.countryOfOrigin)}</span>
            </div>
          </div>
          <div class="result-footer">
            <p class="tier-note">
              Showing basic data. <strong>Upgrade</strong> to Basic or Pro for the full 50+ field spec sheet.
            </p>
            <a href="#pricing" class="cta-small">Sign Up for Full Access →</a>
          </div>
        </div>
      `;
      resultArea.classList.add('visible');
      resultArea.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }

    function renderNotFound(make, model, year) {
      resultArea.innerHTML = `
        <div class="not-found">
          <div class="emoji">🔍</div>
          <h4>No exact match found</h4>
          <p>We couldn't find a <strong>${make} ${model} ${year}</strong> in our database.<br>Try a different year or check your spelling.</p>
        </div>
      `;
      resultArea.classList.add('visible');
    }

    function renderError(msg) {
      resultArea.innerHTML = `<div class="result-error">⚠ ${msg}</div>`;
      resultArea.classList.add('visible');
    }

    // ─── Search ─────────────────────────────────────────────────────────────────
    searchForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      const make  = makeSelect.value;
      const model = modelSelect.value;
      const year  = yearSelect.value;

      if (!make || !model || !year) return;

      // Loading state
      searchBtn.disabled = true;
      searchBtn.innerHTML = '<span class="spinner"></span> Searching…';
      resultArea.classList.remove('visible');
      resultArea.innerHTML = '';
      resultArea.classList.add('visible');
      resultArea.innerHTML = '<div style="text-align:center;padding:40px;color:var(--text-muted);font-size:14px;"><span class="spinner" style="border-color:rgba(249,115,22,0.3);border-top-color:var(--accent);"></span> Searching…</div>';

      try {
        // Try live API first (free tier, no auth)
        const params = new URLSearchParams({ make, model, year });
        const res = await fetch(`https://api.truckpedia.net/api/truck?${params}`);

        if (res.ok) {
          const data = await res.json();
          if (data && data.truck.make) {
            // API returned a match — fetch full details from trucks.json
            const trucksRes = await fetch('/api/trucks.json');
            const trucks = await trucksRes.json();
            const match = trucks.find(t =>
              t.make === data.truck.make &&
              t.model === data.truck.model &&
              String(t.year) === String(data.truck.year)
            );
            if (match) {
              renderResult(match);
            } else {
              renderResult(data);
            }
          } else {
            renderNotFound(make, model, year);
          }
        } else if (res.status === 404) {
          renderNotFound(make, model, year);
        } else {
          throw new Error(`API error: ${res.status}`);
        }
      } catch (_) {
        // Fallback: search local trucks.json
        try {
          const trucksRes = await fetch('/api/trucks.json');
          const trucks = await trucksRes.json();
          // Normalize year comparison
          const match = trucks.find(t =>
            t.make.toLowerCase() === make.toLowerCase() &&
            t.model.toLowerCase() === model.toLowerCase() &&
            String(t.year) === String(year)
          );
          if (match) {
            renderResult(match);
          } else {
            renderNotFound(make, model, year);
          }
        } catch (__) {
          renderError('Unable to reach the API. Please try again.');
        }
      } finally {
        searchBtn.disabled = false;
        searchBtn.innerHTML = 'Search';
      }
    });

    // ─── Smooth scroll for anchor links ─────────────────────────────────────────
    document.querySelectorAll('a[href^="#"]').forEach(a => {
      a.addEventListener('click', e => {
        const target = document.querySelector(a.getAttribute('href'));
        if (target) {
          e.preventDefault();
          target.scrollIntoView({ behavior: 'smooth' });
        }
      });
    });

    // ─── Nav active state ────────────────────────────────────────────────────────
    const path = window.location.pathname;
    if (path.includes('/api/docs') || path.includes('/docs')) {
      document.getElementById('nav-docs')?.classList.add('active');
    } else {
      document.getElementById('nav-home')?.classList.add('active');
    }
  </script>
</body>
</html>
