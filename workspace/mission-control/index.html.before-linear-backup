        function getLunarAge(date) {
            let year = date.getFullYear();
            let month = date.getMonth() + 1;
            let day = date.getDate();
            
            if (month < 3) {
                year--;
                month += 12;
            }
            month++;
            
            const c = 365.25 * year;
            const e = 30.6 * month;
            const jd = c + e + day - 694039.09;
            const totalDays = jd / 29.5305882;
            const age = (totalDays - Math.floor(totalDays)) * 29.5305882;
            
            return age;
        }

        function getMoonPhase(date) {
            const age = getLunarAge(date);
            const phaseIndex = Math.floor((age / 29.5305882) * 8) % 8;
