                    <div class="member-avatar ${member.name === 'LT' ? 'diver' : ''} ${member.name === 'Gunner' ? 'camo' : ''} ${member.name === 'Deckhand' ? 'jolly-roger' : ''} ${member.name === 'Warrant' ? 'anchor' : ''} ${member.isCaptain ? 'captain' : ''}" ${!member.isCaptain && member.name !== 'LT' && member.name !== 'Gunner' && member.name !== 'Deckhand' && member.name !== 'Warrant' ? `style="background: linear-gradient(135deg, var(--accent), #a855f7);"` : ''}>${!member.isCaptain && member.name !== 'LT' && member.name !== 'Gunner' && member.name !== 'Deckhand' && member.name !== 'Warrant' ? member.emoji : ''}</div>
                    <div class="member-name">${member.name}</div>
