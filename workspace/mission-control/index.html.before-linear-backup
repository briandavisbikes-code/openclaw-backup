<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mission Control</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --bg-dark: #0f1419;
            --bg-card: #192734;
            --bg-hover: #22303c;
            --accent: #1d9bf0;
            --accent-hover: #1a8cd8;
            --text-primary: #ffffff;
            --text-secondary: #8899a6;
            --border: #38444d;
            --success: #00ba7c;
            --warning: #ffd400;
            --danger: #f4212e;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background: var(--bg-dark);
            color: var(--text-primary);
            min-height: 100vh;
        }

        /* Header */
        .header {
            background: var(--bg-card);
            padding: 1rem 2rem;
            border-bottom: 1px solid var(--border);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .header h1 {
            font-size: 1.5rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .header h1::before {
            content: "🚀";
        }

        .header #clock {
            font-size: 2rem;
            font-weight: bold;
            font-family: 'Courier New', monospace;
        }

        /* Project Ideas Tab */
        .projects-header {
            padding: 1.5rem 2rem;
            border-bottom: 1px solid var(--border);
            background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
        }

        .projects-header h2 {
            font-size: 1.5rem;
            background: linear-gradient(90deg, #f97316, #fbbf24, #22c55e);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .projects-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
            gap: 1rem;
            padding: 1.5rem 2rem;
        }

        .project-card {
            background: var(--bg-card);
            border-radius: 12px;
            padding: 1rem 1.25rem;
            display: flex;
            gap: 1rem;
            transition: transform 0.2s, box-shadow 0.2s;
        }

        .project-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 25px rgba(0,0,0,0.3);
        }

        .project-rank {
            font-size: 1.5rem;
            font-weight: bold;
            color: var(--text-secondary);
            min-width: 40px;
        }

        .project-content h3 {
            font-size: 1rem;
            margin-bottom: 0.5rem;
            color: var(--text-primary);
        }

        .project-content p {
            font-size: 0.85rem;
            color: var(--text-secondary);
            line-height: 1.5;
            margin-bottom: 0.75rem;
        }

        .project-tag {
            display: inline-block;
            font-size: 0.7rem;
            padding: 0.25rem 0.6rem;
            border-radius: 20px;
            background: rgba(255,255,255,0.1);
            color: var(--accent);
        }

        /* Links Tab */
        .links-header {
            padding: 1.5rem 2rem;
            border-bottom: 1px solid var(--border);
        }

        .links-header h2 {
            font-size: 1.5rem;
        }

        .links-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
            gap: 1rem;
            padding: 2rem;
        }

        .link-card {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 12px;
            padding: 1.5rem;
            text-decoration: none;
            color: var(--text-primary);
            transition: all 0.2s;
        }

        .link-card:hover {
            background: var(--bg-hover);
            border-color: var(--accent);
            transform: translateY(-2px);
        }

        .link-icon {
            font-size: 2rem;
            margin-bottom: 0.5rem;
        }

        .link-title {
            font-size: 0.9rem;
            font-weight: 500;
        }

        /* Notes Tab */
        .notes-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 1rem 2rem;
            border-bottom: 1px solid var(--border);
        }

        .notes-header h2 {
            font-size: 1.5rem;
        }

        .btn-save {
            padding: 0.5rem 1rem;
            background: var(--success);
            color: white;
            border: none;
            border-radius: 6px;
            cursor: pointer;
            font-size: 0.9rem;
        }

        .btn-save:hover {
            opacity: 0.9;
        }

        .notes-container {
            padding: 2rem;
            height: calc(100vh - 200px);
        }

        #notes-textarea {
            width: 100%;
            height: 100%;
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 8px;
            padding: 1rem;
            color: var(--text-primary);
            font-size: 1rem;
            font-family: inherit;
            resize: none;
        }

        #notes-textarea:focus {
            outline: none;
            border-color: var(--accent);
        }

        /* World Clock Tab */
        .clock-header {
            padding: 1rem 2rem;
            border-bottom: 1px solid var(--border);
        }

        .clock-header h2 {
            font-size: 1.5rem;
        }

        .clock-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
            gap: 1rem;
            padding: 2rem;
        }

        .clock-card {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 12px;
            padding: 1.5rem;
            text-align: center;
            transition: transform 0.2s;
        }

        .clock-card:hover {
            transform: translateY(-2px);
            border-color: var(--accent);
        }

        .clock-city {
            font-size: 1.1rem;
            font-weight: 600;
            margin-bottom: 0.25rem;
            color: var(--text-primary);
        }

        .clock-tz {
            font-size: 0.75rem;
            color: var(--accent);
            margin-bottom: 0.5rem;
        }

        .clock-time {
            font-size: 1.5rem;
            font-weight: 700;
            font-family: 'SF Mono', 'Menlo', 'Monaco', 'Courier New', monospace;
            color: #22c55e;
            margin-bottom: 0.25rem;
            text-shadow: 0 0 10px rgba(34, 197, 94, 0.3);
        }

        .clock-date {
            font-size: 0.85rem;
            color: var(--text-secondary);
        }

        /* Lunar Tab */
        .lunar-header {
            padding: 1rem 2rem;
            border-bottom: 1px solid var(--border);
        }

        .lunar-header h2 {
            font-size: 1.5rem;
        }

        .lunar-content {
            padding: 2rem;
        }

        .lunar-main {
            text-align: center;
            margin-bottom: 2rem;
        }

        .moon-phase-icon {
            font-size: 6rem;
            margin-bottom: 1rem;
            filter: drop-shadow(0 0 20px rgba(255, 255, 255, 0.3));
        }

        .moon-phase-name {
            font-size: 2rem;
            font-weight: 600;
            color: var(--text-primary);
            margin-bottom: 0.5rem;
        }

        .moon-illumination {
            font-size: 1.1rem;
            color: var(--accent);
        }

        .lunar-details {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
            gap: 1rem;
            margin-bottom: 2rem;
        }

        .lunar-card {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 12px;
            padding: 1rem;
            text-align: center;
        }

        .lunar-label {
            font-size: 0.8rem;
            color: var(--text-secondary);
            margin-bottom: 0.5rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .lunar-value {
            font-size: 1.1rem;
            font-weight: 600;
            color: var(--text-primary);
        }

        .lunar-calendar {
            margin-top: 1rem;
        }

        .lunar-calendar-title {
            font-size: 1.1rem;
            font-weight: 600;
            margin-bottom: 1rem;
            color: var(--text-primary);
        }

        .zodiac-sidebar {
            position: fixed;
            right: 2rem;
            top: 180px;
            width: 320px;
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 12px;
            padding: 1.5rem;
        }

        .zodiac-sidebar-title {
            font-size: 0.9rem;
            color: var(--text-secondary);
            margin-bottom: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .zodiac-main-sign {
            font-size: 1.8rem;
            font-weight: 700;
            color: var(--accent);
            margin-bottom: 0.25rem;
        }

        .zodiac-dates {
            font-size: 1rem;
            color: var(--text-secondary);
            margin-bottom: 1rem;
        }

        .zodiac-element {
            font-size: 0.9rem;
            color: var(--text-secondary);
            margin-bottom: 1rem;
            padding: 0.5rem;
            background: var(--bg-dark);
            border-radius: 6px;
        }

        .zodiac-traits {
            margin-bottom: 1rem;
        }

        .zodiac-trait-title {
            font-size: 0.8rem;
            color: var(--text-secondary);
            margin-bottom: 0.5rem;
            text-transform: uppercase;
        }

        .zodiac-traits-list {
            font-size: 0.95rem;
            color: var(--text-primary);
        }

        .zodiac-lucky {
            display: flex;
            gap: 1.5rem;
            font-size: 0.9rem;
            margin-bottom: 1rem;
            padding: 0.75rem;
            background: var(--bg-dark);
            border-radius: 6px;
        }

        .zodiac-lucky span {
            color: var(--accent);
            font-weight: 600;
        }

        .zodiac-mood {
            border-top: 1px solid var(--border);
            padding-top: 1rem;
        }

        .zodiac-mood-title {
            font-size: 0.8rem;
            color: var(--text-secondary);
            margin-bottom: 0.5rem;
            text-transform: uppercase;
        }

        .zodiac-mood-text {
            font-size: 1rem;
            color: var(--text-primary);
            font-style: italic;
            line-height: 1.5;
        }

        .lunar-days {
            display: flex;
            gap: 0.5rem;
            flex-wrap: wrap;
        }

        .lunar-day {
            width: 40px;
            height: 40px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 50%;
            font-size: 1.2rem;
            background: var(--bg-card);
            border: 1px solid var(--border);
            cursor: default;
        }

        .lunar-day.today {
            border-color: var(--accent);
            box-shadow: 0 0 10px rgba(29, 155, 240, 0.5);
        }

        .lunar-day.full {
            background: #fbbf24;
            border-color: #fbbf24;
        }

        .lunar-day.new {
            background: #333;
            border-color: #555;
        }

        /* Water Levels Tab */
        .water-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 1rem 2rem;
            border-bottom: 1px solid var(--border);
        }

        .water-header h2 {
            font-size: 1.5rem;
        }

        .water-summary {
            padding: 0.75rem 2rem;
            background: var(--bg-card);
            border-bottom: 1px solid var(--border);
            font-size: 0.85rem;
            color: var(--text-secondary);
        }

        .water-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
            gap: 1rem;
            padding: 1.5rem 2rem;
        }

        .water-card {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 12px;
            padding: 1.25rem;
            transition: transform 0.2s;
        }

        .water-card:hover {
            transform: translateY(-2px);
        }

        .water-name {
            font-size: 1rem;
            font-weight: 600;
            color: var(--text-primary);
            margin-bottom: 0.5rem;
        }

        .water-percent {
            font-size: 2rem;
            font-weight: 700;
            font-family: 'SF Mono', 'Menlo', monospace;
            margin-bottom: 0.5rem;
        }

        .water-trend {
            font-size: 1.8rem;
        }

        .water-trend.up {
            color: #22c55e;
        }

        .water-trend.down {
            color: #ef4444;
        }

        .water-bar-bg {
            height: 8px;
            background: var(--bg-dark);
            border-radius: 4px;
            overflow: hidden;
            margin-bottom: 0.5rem;
        }

        .water-bar-fill {
            height: 100%;
            border-radius: 4px;
            transition: width 0.5s ease;
        }

        .water-capacity {
            font-size: 0.75rem;
            color: var(--text-secondary);
        }

        /* Tab Navigation */
        .tabs {
            display: flex;
            background: var(--bg-card);
            padding: 0 2rem;
            border-bottom: 1px solid var(--border);
            gap: 0.5rem;
        }

        .tab-btn {
            background: transparent;
            border: none;
            color: var(--text-secondary);
            padding: 1rem 1.5rem;
            cursor: pointer;
            font-size: 1rem;
            border-bottom: 2px solid transparent;
            transition: all 0.2s;
        }

        .tab-btn:hover {
            color: var(--text-primary);
            background: var(--bg-hover);
        }

        .tab-btn.active {
            color: var(--accent);
            border-bottom-color: var(--accent);
        }

        /* Tab Content */
        .tab-content {
            display: none;
            padding: 2rem;
        }

        .tab-content.active {
            display: block;
        }

        /* Kanban Board */
        .kanban-board {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 1rem;
            min-height: 500px;
        }

        .kanban-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 1rem 2rem;
            border-bottom: 1px solid var(--border);
        }

        .kanban-header h2 {
            font-size: 1.5rem;
        }

        .btn-refresh {
            padding: 0.5rem 1rem;
            background: var(--accent);
            color: white;
            border: none;
            border-radius: 6px;
            cursor: pointer;
            font-size: 0.9rem;
        }

        .btn-refresh:hover {
            background: var(--accent-hover);
        }

        .kanban-column {
            background: var(--bg-card);
            border-radius: 8px;
            padding: 1rem;
            min-height: 400px;
        }

        .column-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 1rem;
            padding-bottom: 0.5rem;
            border-bottom: 1px solid var(--border);
        }

        .column-header h3 {
            font-size: 0.9rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            color: var(--text-secondary);
        }

        .column-count {
            background: var(--bg-hover);
            padding: 0.2rem 0.5rem;
            border-radius: 12px;
            font-size: 0.8rem;
        }

        .task-card {
            background: var(--bg-dark);
            border: 1px solid var(--border);
            border-radius: 6px;
            padding: 0.5rem;
            margin-bottom: 0.5rem;
            cursor: grab;
            transition: all 0.2s;
            font-size: 0.85rem;
        }

        .task-card:hover {
            border-color: var(--accent);
            transform: translateY(-2px);
        }

        .task-card.dragging {
            opacity: 0.5;
        }

        .task-title {
            font-weight: 600;
            margin-bottom: 0.25rem;
            font-size: 0.9rem;
        }

        .task-description {
            font-size: 0.75rem;
            color: var(--text-secondary);
            margin-bottom: 0.5rem;
            line-height: 1.3;
        }

        .task-tags {
            display: flex;
            gap: 0.25rem;
            flex-wrap: wrap;
        }

        .tag {
            padding: 0.15rem 0.4rem;
            border-radius: 12px;
            font-size: 0.65rem;
            font-weight: 500;
        }

        .tag-truckpedia { background: #61358320; color: #a855f7; }
        .tag-website { background: #1d9bf020; color: #1d9bf0; }
        .tag-3d-printing { background: #00ba7c20; color: #00ba7c; }
        .tag-crypto { background: #ffd40020; color: #ffd400; }

        .add-task-btn {
            width: 100%;
            padding: 0.75rem;
            background: transparent;
            border: 1px dashed var(--border);
            border-radius: 8px;
            color: var(--text-secondary);
            cursor: pointer;
            transition: all 0.2s;
        }

        .add-task-btn:hover {
            border-color: var(--accent);
            color: var(--accent);
        }

        /* Calendar */
        .calendar-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 1.5rem;
        }

        .calendar-header h2 {
            font-size: 1.5rem;
        }

        .calendar-nav {
            display: flex;
            align-items: center;
            gap: 1rem;
        }

        .calendar-nav button {
            background: var(--bg-card);
            border: 1px solid var(--border);
            color: var(--text-primary);
            padding: 0.5rem 1rem;
            border-radius: 6px;
            cursor: pointer;
        }

        .calendar-nav button:hover {
            background: var(--bg-hover);
        }

        .calendar-grid {
            display: grid;
            grid-template-columns: repeat(7, 1fr);
            gap: 1px;
            background: var(--border);
            border-radius: 8px;
            overflow: hidden;
        }

        .calendar-day-header {
            background: var(--bg-card);
            padding: 0.75rem;
            text-align: center;
            font-weight: 600;
            font-size: 0.85rem;
            color: var(--text-secondary);
        }

        .calendar-day {
            background: var(--bg-dark);
            min-height: 100px;
            padding: 0.5rem;
        }

        .calendar-day.other-month {
            opacity: 0.4;
        }

        .calendar-day.today {
            background: var(--bg-card);
        }

        .day-number {
            font-size: 0.85rem;
            color: var(--text-secondary);
            margin-bottom: 0.5rem;
        }

        .calendar-day.today .day-number {
            color: var(--accent);
            font-weight: 700;
        }

        .calendar-view-week .calendar-day {
            min-height: 400px;
        }

        .calendar-view-week .day-task {
            font-size: 0.85rem;
            padding: 0.4rem 0.6rem;
            margin-bottom: 0.25rem;
        }

        .day-tasks {
            display: flex;
            flex-direction: column;
            gap: 0.25rem;
        }

        .day-task {
            font-size: 0.75rem;
            padding: 0.25rem 0.5rem;
            border-radius: 4px;
            background: var(--bg-card);
            border-left: 3px solid var(--accent);
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .day-task.priority-high {
            border-left-color: var(--danger);
        }

        .day-task.priority-medium {
            border-left-color: var(--warning);
        }

        .day-task.priority-low {
            border-left-color: var(--success);
        }

        /* Team Members */
        .team-header {
            margin-bottom: 2rem;
        }

        .team-header h2 {
            font-size: 1.5rem;
            margin-bottom: 0.5rem;
        }

        .mission-statement {
            background: var(--bg-card);
            border: 1px solid var(--accent);
            border-radius: 8px;
            padding: 1.5rem;
            margin-bottom: 2rem;
        }

        .mission-statement h3 {
            color: var(--accent);
            margin-bottom: 0.5rem;
            font-size: 0.9rem;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .mission-statement p {
            color: #ffffff;
            line-height: 1.6;
            font-size: 1.3rem;
            font-family: 'Comic Sans MS', 'Chalkboard SE', sans-serif;
        }

        .team-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 1.5rem;
        }

        .systems-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 2rem;
        }

        .systems-header h2 {
            font-size: 1.5rem;
        }

        .systems-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 1.5rem;
        }

        .system-card {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 12px;
            padding: 1.5rem;
        }

        .system-card.status-healthy {
            border-color: var(--success);
        }

        .system-card.status-warning {
            border-color: var(--warning);
        }

        .system-card.status-error {
            border-color: var(--danger);
        }

        .system-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 1rem;
        }

        .system-name {
            font-size: 1.1rem;
            font-weight: 600;
        }

        .system-status {
            padding: 0.25rem 0.75rem;
            border-radius: 12px;
            font-size: 0.8rem;
            font-weight: 600;
        }

        .status-healthy .system-status {
            background: var(--success)20;
            color: var(--success);
        }

        .status-warning .system-status {
            background: var(--warning)20;
            color: var(--warning);
        }

        .status-error .system-status {
            background: var(--danger)20;
            color: var(--danger);
        }

        .system-metric {
            display: flex;
            justify-content: space-between;
            margin-bottom: 0.5rem;
            font-size: 0.9rem;
        }

        .system-metric-label {
            color: var(--text-secondary);
        }

        .system-metric-value {
            font-weight: 600;
        }

        .progress-bar {
            height: 8px;
            background: var(--bg-dark);
            border-radius: 4px;
            overflow: hidden;
            margin-top: 0.5rem;
        }

        .progress-fill {
            height: 100%;
            border-radius: 4px;
            transition: width 0.3s;
        }

        .progress-fill.healthy {
            background: var(--success);
        }

        .progress-fill.warning {
            background: var(--warning);
        }

        .progress-fill.danger {
            background: var(--danger);
        }

        .cron-jobs-list {
            margin-top: 0.75rem;
            border-top: 1px solid var(--border);
            padding-top: 0.75rem;
        }

        .cron-job-item {
            margin-bottom: 0.5rem;
        }

        .cron-job-name {
