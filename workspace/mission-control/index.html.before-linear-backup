        // Systems Functions
        let systemsData = [];

        async function refreshSystems() {
            const grid = document.getElementById('systems-grid');
            grid.innerHTML = '<div class="system-card"><p>Loading system data...</p></div>';
            
            try {
                const response = await fetch('/systems.json?v=' + Date.now());
                const data = await response.json();
                
                const diskPercent = data.disk.percent;
                
                systemsData = [
                    {
                        name: 'Disk Usage',
                        status: diskPercent > 90 ? 'error' : diskPercent > 75 ? 'warning' : 'healthy',
                        metrics: [
                            { label: 'Total', value: data.disk.total },
                            { label: 'Used', value: data.disk.used },
                            { label: 'Available', value: data.disk.available },
                            { label: 'Usage', value: diskPercent + '%', isPercent: true }
                        ]
                    },
                    {
                        name: 'Memory',
                        status: data.memory.active > 8000 ? 'error' : data.memory.active > 6000 ? 'warning' : 'healthy',
                        metrics: [
                            { label: 'Total', value: data.memory.total },
                            { label: 'Active Pages', value: data.memory.active }
                        ]
                    },
                    {
                        name: 'Cron Jobs',
                        status: 'healthy',
                        total: data.cron.jobsEnabled,
                        jobs: data.cron.jobs || []
                    },
                    {
                        name: 'OpenClaw',
                        status: data.openclaw.gateway === 'running' ? 'healthy' : 'warning',
                        metrics: [
                            { label: 'Gateway', value: data.openclaw.gateway },
                            { label: 'Version', value: data.openclaw.version }
                        ],
                        llms: data.openclaw.llms || []
                    }
                ];
                
                renderSystems();
            } catch (err) {
                grid.innerHTML = `<div class="system-card status-error"><p>Error loading systems: ${err.message}</p></div>`;
            }
        }

        function renderSystems() {
            const grid = document.getElementById('systems-grid');
            grid.innerHTML = systemsData.map(system => `
                <div class="system-card status-${system.status}">
                    <div class="system-header">
                        <span class="system-name">${system.name}</span>
                        <span class="system-status">${system.status.toUpperCase()}</span>
                    </div>
                    ${system.jobs && system.jobs.length > 0 ? `
                        <div class="system-metric">
                            <span class="system-metric-label">Total Jobs</span>
                            <span class="system-metric-value">${system.total}</span>
                        </div>
                        <div class="cron-jobs-list">
                            ${system.jobs.map(job => `
                                <div class="cron-job-item">
                                    <div class="cron-job-name">${job.name}</div>
                                    <div class="cron-job-details">${job.time} → ${job.target}</div>
                                </div>
                            `).join('')}
                        </div>
                    ` : ''}
                    ${system.metrics ? system.metrics.map(m => `
                        <div class="system-metric">
                            <span class="system-metric-label">${m.label}</span>
                            <span class="system-metric-value">${m.value}</span>
                        </div>
                        ${m.isPercent ? `
                        <div class="progress-bar">
                            <div class="progress-fill ${system.status}" style="width: ${m.value}"></div>
                        </div>
                        ` : ''}
                    `).join('') : ''}
                    ${system.llms && system.llms.length > 0 ? `
                        <div class="llms-list" style="margin-top: 0.75rem; border-top: 1px solid var(--border); padding-top: 0.75rem;">
                            ${system.llms.map(llm => `
                                <div class="llm-item" style="display: flex; justify-content: space-between; padding: 0.3rem 0;">
                                    <span class="llm-name" style="font-size: 0.85rem; font-weight: 600; color: var(--accent);">${llm.name}</span>
                                    <span class="llm-provider" style="font-size: 0.75rem; color: var(--text-secondary);">${llm.provider}</span>
                                </div>
                            `).join('')}
                        </div>
                    ` : ''}
                </div>
            `).join('');
        }

        // Initialize
        renderTasks();
        renderCalendar();
        renderTeam();
        
        // Load tasks from JSON
        loadTasks();
        
        // Load notes
        loadNotes();
        
        // Update lunar data
        updateLunar();
        updateWaterLevels();
        
        // Load systems when tab is clicked
        document.querySelectorAll('.tab-btn').forEach(btn => {
            btn.addEventListener('click', () => {
                if (btn.dataset.tab === 'systems') {
                    refreshSystems();
                }
            });
        });

        // Close modal on outside click
        document.getElementById('task-modal').addEventListener('click', (e) => {
            if (e.target.classList.contains('modal-overlay')) {
                closeTaskModal();
            }
        });
    
        // Linear Issues
        const LINEAR_API_KEY = 'lin_api_u7B8A9Bkc9Txda7UptAIHvZydCsfavuAcCRzGKVp';
        async function refreshLinearIssues() {
            const btn = document.getElementById('linear-refresh-btn');
            if (!btn) return;
            btn.textContent = 'Loading...';
            btn.disabled = true;
            try {
                const res = await fetch('https://api.linear.app/graphql', {
                    method: 'POST',
                    headers: { 'Authorization': LINEAR_API_KEY, 'Content-Type': 'application/json' },
                    body: JSON.stringify({ query: `query { viewer { workspace { issues(first:50) { nodes { id identifier title state { name type } priority assignee { name avatarUrl } createdAt updatedAt url } } } } }` })
                });
                const json = await res.json();
                if (json.errors) throw new Error(json.errors[0].message);
                const issues = json.data?.viewer?.workspace?.issues?.nodes || [];
                document.getElementById('linear-stats').textContent = issues.length + ' issues';
                const stateMap = { 'backlog':'Backlog', 'triage':'Todo', 'todo':'Todo', 'in_progress':'In Progress', 'completed':'Done' };
                ['Backlog','Todo','In Progress','Done'].forEach(s => {
                    const el = document.getElementById('issues-' + s.toLowerCase().replace(' ',''));
                    const cnt = document.getElementById('count-' + s.toLowerCase().replace(' ',''));
                    const stateIssues = issues.filter(i => (stateMap[i.state?.type] || i.state?.name) === s);
                    if (cnt) cnt.textContent = stateIssues.length;
                    if (el) el.innerHTML = stateIssues.length === 0 ? 'No issues' : stateIssues.map(i => '<div class="issue-card"><div class="issue-title">' + i.identifier + ' - ' + i.title + '</div><div class="issue-meta"><span>' + (i.assignee?.name||'Unassigned') + '</span></div></div>').join('');
                });
            } catch(e) { document.getElementById('linear-stats').textContent = 'Error: ' + e.message; }
            btn.textContent = 'Refresh';
            btn.disabled = false;
        }
        document.querySelectorAll('.tab-btn').forEach(btn => {
            btn.addEventListener('click', function() {
                if (btn.dataset.tab === 'linear') setTimeout(refreshLinearIssues, 150);
            });
        });
