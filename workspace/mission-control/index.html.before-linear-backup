            const hours = now.getHours();
            const moonriseHour = Math.floor((phase.age * 2) % 24);
            const moonsetHour = (moonriseHour + 12) % 24;
            
            document.getElementById('moonrise').textContent = 
                String(moonriseHour).padStart(2, '0') + ':00';
            document.getElementById('moonset').textContent = 
                String(moonsetHour).padStart(2, '0') + ':00';
            
            document.getElementById('next-full').textContent = getNextFullMoon();
            document.getElementById('next-new').textContent = getNextNewMoon();
            
            const dayOfCycle = Math.floor(phase.age) + 1;
            document.getElementById('lunar-day').textContent = 'Day ' + dayOfCycle;
            
            const zodiac = getZodiac(now);
            document.getElementById('zodiac').textContent = zodiac.emoji + ' ' + zodiac.name;
            
            // Update zodiac sidebar
            document.getElementById('zodiac-main').textContent = zodiac.emoji + ' ' + zodiac.name;
            document.getElementById('zodiac-dates').textContent = `${zodiac.start[0]}/${zodiac.start[1]} - ${zodiac.end[0]}/${zodiac.end[1]}`;
            document.getElementById('zodiac-element').textContent = 'Element: ' + zodiac.element;
            document.getElementById('zodiac-traits').textContent = zodiac.traits;
            document.getElementById('lucky-number').textContent = zodiac.lucky;
            document.getElementById('lucky-color').textContent = zodiac.color;
            
            // Generate horoscope based on moon phase + zodiac
            const phaseName = phase.name;
            const signName = zodiac.name;
            const horoscope = generateHoroscope(phaseName, signName, zodiac.element);
            document.getElementById('horoscope-reading').textContent = horoscope;
            
            // Render 30-day cycle
            const daysContainer = document.getElementById('lunar-days');
            let daysHtml = '';
            for (let i = 0; i < 30; i++) {
                const date = new Date(now);
                date.setDate(date.getDate() - Math.floor(phase.age) + i);
                const p = getMoonPhase(date);
                const isToday = i === Math.floor(phase.age);
                const isFull = p.name === 'Full Moon';
                const isNew = p.name === 'New Moon';
                
                let classes = 'lunar-day';
                if (isToday) classes += ' today';
                if (isFull) classes += ' full';
                if (isNew) classes += ' new';
                
                daysHtml += `<div class="${classes}" title="${p.name}">${p.icon}</div>`;
            }
            daysContainer.innerHTML = daysHtml;
        }

        // Water Levels Functions
        async function updateWaterLevels() {
            try {
                const response = await fetch('/water.json?v=' + Date.now());
                const data = await response.json();
                
                document.getElementById('water-date').textContent = data.lastUpdated || new Date().toLocaleDateString();
                
                const grid = document.getElementById('water-grid');
                grid.innerHTML = data.reservoirs.map(r => {
                    const color = r.percent >= 75 ? '#22c55e' : r.percent >= 50 ? '#fbbf24' : r.percent >= 35 ? '#ec4899' : '#ef4444';
                    const trend = r.trend === 'up' ? '↑' : '↓';
                    return `
                        <div class="water-card">
                            <div class="waterName">${r.name}</div>
                            <div class="water-percent" style="color: ${color};">${r.percent}% <span class="water-trend ${r.trend}">${trend}</span></div>
                            <div class="water-bar-bg">
                                <div class="water-bar-fill" style="width: ${r.percent}%; background: ${color};"></div>
                            </div>
                            <div class="water-capacity">${r.current}M AF / ${r.capacity}M AF</div>
                        </div>
                    `;
                }).join('');
            } catch (err) {
                document.getElementById('water-grid').innerHTML = '<p>Error loading data. Click refresh to try again.</p>';
            }
        }

        // Kanban Functions
        function renderTasks() {
            document.querySelectorAll('.kanban-column').forEach(column => {
                const status = column.dataset.status;
                const container = column.querySelector('.tasks-container');
                const statusTasks = tasks.filter(t => t.status === status);
                
                container.innerHTML = statusTasks.map(task => `
                    <div class="task-card" draggable="true" data-id="${task.id}">
                        <div class="task-title">${task.title}</div>
                        <div class="task-description">${task.description || ''}</div>
                        <div class="task-tags">
                            <span class="tag tag-${task.project}">${task.project}</span>
                        </div>
                    </div>
                `).join('');

                column.querySelector('.column-count').textContent = statusTasks.length;
            });

            setupDragAndDrop();
            saveTasks();
        }

        function setupDragAndDrop() {
            document.querySelectorAll('.task-card').forEach(card => {
                card.addEventListener('dragstart', (e) => {
                    e.target.classList.add('dragging');
                    e.dataTransfer.setData('text/plain', e.target.dataset.id);
                });
                card.addEventListener('dragend', (e) => {
                    e.target.classList.remove('dragging');
                });
            });

            document.querySelectorAll('.kanban-column').forEach(column => {
                column.addEventListener('dragover', (e) => {
                    e.preventDefault();
                });
                column.addEventListener('drop', (e) => {
                    e.preventDefault();
                    const taskId = e.dataTransfer.getData('text/plain');
                    const newStatus = column.dataset.status;
                    tasks = tasks.map(t => t.id == taskId ? { ...t, status: newStatus } : t);
                    renderTasks();
                });
            });
        }

        function openTaskModal(status = 'backlog', taskId = null) {
            const modal = document.getElementById('task-modal');
            const form = document.getElementById('task-form');
            
            if (taskId) {
                const task = tasks.find(t => t.id == taskId);
                document.getElementById('modal-title').textContent = 'Edit Task';
                document.getElementById('task-id').value = task.id;
                document.getElementById('task-title').value = task.title;
                document.getElementById('task-description').value = task.description || '';
                document.getElementById('task-project').value = task.project;
                document.getElementById('task-status').value = task.status;
            } else {
                document.getElementById('modal-title').textContent = 'Add New Task';
                form.reset();
                document.getElementById('task-id').value = '';
                document.getElementById('task-status').value = status;
            }
            
            modal.classList.add('active');
        }

        function closeTaskModal() {
            document.getElementById('task-modal').classList.remove('active');
        }

        document.getElementById('task-form').addEventListener('submit', (e) => {
            e.preventDefault();
            const id = document.getElementById('task-id').value;
            const taskData = {
                title: document.getElementById('task-title').value,
                description: document.getElementById('task-description').value,
                project: document.getElementById('task-project').value,
                status: document.getElementById('task-status').value
            };

            if (id) {
                tasks = tasks.map(t => t.id == id ? { ...t, ...taskData } : t);
            } else {
                tasks.push({ id: Date.now(), ...taskData });
            }

            renderTasks();
            closeTaskModal();
        });

        function saveTasks() {
            localStorage.setItem('mc-tasks', JSON.stringify(tasks));
        }

        // Calendar Functions
        function renderCalendar() {
            const grid = document.getElementById('calendar-grid');
            const title = document.getElementById('calendar-title');
            const months = ['January', 'February', 'March', 'April', 'May', 'June', 
                          'July', 'August', 'September', 'October', 'November', 'December'];
            
            const today = new Date();
            
            if (calendarView === 'week') {
                // Week view - show current week
                const startOfWeek = new Date(today);
                startOfWeek.setDate(today.getDate() - today.getDay());
                
                const endOfWeek = new Date(startOfWeek);
                endOfWeek.setDate(startOfWeek.getDate() + 6);
                
                title.textContent = `${months[startOfWeek.getMonth()]} ${startOfWeek.getDate()} - ${endOfWeek.getDate()}, ${startOfWeek.getFullYear()}`;
                
                let html = ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'].map(d => 
                    `<div class="calendar-day-header">${d}</div>`
                ).join('');
                
                for (let i = 0; i < 7; i++) {
                    const currentDate = new Date(startOfWeek);
                    currentDate.setDate(startOfWeek.getDate() + i);
                    const dateStr = `${currentDate.getFullYear()}-${String(currentDate.getMonth() + 1).padStart(2, '0')}-${String(currentDate.getDate()).padStart(2, '0')}`;
                    const dayTasks = calendarTasks.filter(t => t.date === dateStr || t.recurring);
                    const isToday = currentDate.toDateString() === today.toDateString();
                    
                    html += `
                        <div class="calendar-day ${isToday ? 'today' : ''}">
                            <div class="day-number">${currentDate.getDate()}</div>
                            <div class="day-tasks">
                                ${dayTasks.map(t => `
                                    <div class="day-task priority-${t.priority}">${t.recurring ? '🔄 ' : ''}${t.title}</div>
                                `).join('')}
                            </div>
                        </div>
                    `;
                }
                
                grid.innerHTML = html;
                return;
            }
            
            // Month view (original)
            title.textContent = `${months[currentMonth]} ${currentYear}`;

            const firstDay = new Date(currentYear, currentMonth, 1).getDay();
            const daysInMonth = new Date(currentYear, currentMonth + 1, 0).getDate();
            const daysInPrevMonth = new Date(currentYear, currentMonth, 0).getDate();
            
            const isCurrentMonth = today.getMonth() === currentMonth && today.getFullYear() === currentYear;

            let html = ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'].map(d => 
                `<div class="calendar-day-header">${d}</div>`
            ).join('');

            // Previous month days
            for (let i = firstDay - 1; i >= 0; i--) {
                html += `<div class="calendar-day other-month"><div class="day-number">${daysInPrevMonth - i}</div></div>`;
            }

            // Current month days
            for (let day = 1; day <= daysInMonth; day++) {
                const dateStr = `${currentYear}-${String(currentMonth + 1).padStart(2, '0')}-${String(day).padStart(2, '0')}`;
                const dayTasks = calendarTasks.filter(t => t.date === dateStr || t.recurring);
                const isToday = isCurrentMonth && day === today.getDate();
                
                html += `
                    <div class="calendar-day ${isToday ? 'today' : ''}">
                        <div class="day-number">${day}</div>
                        <div class="day-tasks">
                            ${dayTasks.map(t => `
                                <div class="day-task priority-${t.priority}">${t.recurring ? '🔄 ' : ''}${t.title}</div>
                            `).join('')}
                        </div>
                    </div>
                `;
            }

            // Next month days
            const totalCells = firstDay + daysInMonth;
            const remainingCells = 7 - (totalCells % 7);
            if (remainingCells < 7) {
                for (let i = 1; i <= remainingCells; i++) {
                    html += `<div class="calendar-day other-month"><div class="day-number">${i}</div></div>`;
                }
            }

            grid.innerHTML = html;
        }

        function changeMonth(delta) {
            if (calendarView === 'week') {
                // Move by week in week view
                const today = new Date();
                today.setDate(today.getDate() + (delta * 7));
                currentMonth = today.getMonth();
                currentYear = today.getFullYear();
            } else {
                // Move by month in month view
                if (delta === 0) {
                    currentMonth = new Date().getMonth();
                    currentYear = new Date().getFullYear();
                } else {
                    currentMonth += delta;
                    if (currentMonth > 11) {
                        currentMonth = 0;
                        currentYear++;
                    } else if (currentMonth < 0) {
                        currentMonth = 11;
                        currentYear--;
                    }
                }
            }
            renderCalendar();
        }

        function toggleCalendarView() {
            calendarView = calendarView === 'month' ? 'week' : 'month';
            document.getElementById('view-toggle').textContent = calendarView === 'month' ? 'Week' : 'Month';
            
            const grid = document.getElementById('calendar-grid');
            if (calendarView === 'week') {
                grid.classList.add('calendar-view-week');
            } else {
                grid.classList.remove('calendar-view-week');
            }
            
            renderCalendar();
        }

